{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://tracker-server.zitronica.co.mz/api/$1"
    },
    {
      "source": "/api/socket",
      "destination": "wss://tracker-server.zitronica.co.mz/api/socket"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
